# Schedule daily-check via your platform (e.g. Coolify scheduled task), not in-app cron.
# Command after build: node dist/scripts/daily-check.js

# Ntfy configuration
NTFY_TOPIC=
NTFY_BASE_URL=https://ntfy.sh

# Portfolio configuration
# Dollar target for scaling scraped trades (model notionals).
PORTFOLIO_SIZE=10000
# Optional: max long equity exposure before buys are clipped (per strategy sleeve when running daily check — gemini, scorpio, etc. each get their own cap against PORTFOLIO_SIZE).
# Use 0 to disable clipping entirely.
# If unset, defaults to the same value as PORTFOLIO_SIZE (legacy).
# PORTFOLIO_EXPOSURE_CAP=0

# Scraper login (required for SystemTrader portfolio)
LOGIN_EMAIL=
LOGIN_PASSWORD=

# API configuration
API_URL=https://www.equialgo.com/data/backtest/momentum_backtest.json

# Retry configuration (scraper page-level)
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Job-level: retry full daily check when scrape fails (attempts, delay in ms between attempts)
# SCRAPE_JOB_RETRY_ATTEMPTS=3
# SCRAPE_JOB_RETRY_DELAY_MS=60000

# Daily check skips Saturday/Sunday in this IANA timezone (scheduled runs and UI "Run daily check").
# DAILY_CHECK_TIMEZONE=America/New_York
# DAILY_CHECK_ALLOW_WEEKENDS=true

# Database configuration (Turso/LibSQL)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Schwab: register this exact callback URL in the Schwab developer app (no trailing slash):
# SCHWAB_REDIRECT_URI=https://equialgo.coolify.chapilabs.com/callback
# Optional when reverse-proxy headers are unreliable:
# PUBLIC_URL=https://equialgo.coolify.chapilabs.com
# If Coolify forwards a different path to Node than SCHWAB_REDIRECT_URI, set what Node sees:
# SCHWAB_CALLBACK_INCOMING_PATH=/callback

# Weekly report email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

SCHWAB_CLIENT_SECRET=