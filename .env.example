# Schedule daily-check via your platform (e.g. Coolify scheduled task), not in-app cron.
# Command after build: node dist/scripts/daily-check.js

# Ntfy configuration
NTFY_TOPIC=
NTFY_BASE_URL=https://ntfy.sh

# Portfolio configuration
PORTFOLIO_SIZE=10000

# Scraper login (required for SystemTrader portfolio)
LOGIN_EMAIL=
LOGIN_PASSWORD=

# API configuration
API_URL=https://www.equialgo.com/data/backtest/momentum_backtest.json

# Retry configuration (scraper page-level)
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Job-level: retry full daily check when scrape fails (attempts, delay in ms between attempts)
# SCRAPE_JOB_RETRY_ATTEMPTS=3
# SCRAPE_JOB_RETRY_DELAY_MS=60000

# Daily check skips Saturday/Sunday in this IANA timezone (scheduled runs and UI "Run daily check").
# DAILY_CHECK_TIMEZONE=America/New_York
# DAILY_CHECK_ALLOW_WEEKENDS=true

# Database configuration (Turso/LibSQL)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Schwab: on a public server set SCHWAB_REDIRECT_URI to the exact callback URL registered in the Schwab app
# (e.g. https://your-host/api/schwab/callback). Without it, OAuth uses https://127.0.0.1:8765/callback (local only).
# SCHWAB_REDIRECT_URI=https://your-host/api/schwab/callback
# If a reverse proxy forwards a different path to Node than the path in SCHWAB_REDIRECT_URI, set the path Node sees:
# SCHWAB_CALLBACK_INCOMING_PATH=/api/schwab/callback

SCHWAB_CLIENT_SECRET=